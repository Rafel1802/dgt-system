# ─── QUEUE ────────────────────────────────────────────────────────────────────
# Set to 'database' for simple setup (jobs stored in MySQL).
# For production, switch to 'redis' for better performance.
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─── GOOGLE WORKSPACE SMTP RELAY ─────────────────────────────────────────────
# Setup guide:
#   1. In Google Admin Console → Apps → Google Workspace → Gmail
#      → Default routing → Configure SMTP relay service
#   2. Add your server IP to the allowed senders list
#   3. Set authentication to "Require SMTP Authentication"
#   4. Use an app-specific password or OAuth2 token
#
# Option A: SMTP Relay (Recommended for server-to-server)
#   Host: smtp-relay.gmail.com | Port: 587 (TLS) or 465 (SSL)
#
# Option B: Gmail App Password (simpler, requires 2FA on Google account)
#   Host: smtp.gmail.com | Port: 587 | Username: your.email@yourdomain.com
#   Password: 16-character App Password from myaccount.google.com/apppasswords

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp-relay.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your-google-workspace-app-password
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"
# Optional: Reply-to address (e.g. your support inbox)
MAIL_REPLY_TO=support@yourdomain.com

# ─── GMAIL API (Phase 5) ─────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# ─── EBAY SELL API (Phase 5) ─────────────────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_ENVIRONMENT=sandbox

# ─── GOOGLE SHEETS EXPORT (Call Reports) ─────────────────────────────────────
# Absolute path to a Google Cloud service-account JSON key with the Sheets
# and Drive APIs enabled. Until this is set, "Export to Google Sheet" fails
# gracefully with an instructional error instead of exporting.
GOOGLE_SERVICE_ACCOUNT_PATH=

# ─── SECURITY ─────────────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15
TWO_FACTOR_ENABLED=false

# ─── BACKUP ───────────────────────────────────────────────────────────────────
BACKUP_DISK=local
BACKUP_DESTINATION_PATH=backups

VITE_APP_NAME="${APP_NAME}"

